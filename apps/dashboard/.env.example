# Dev: Vite proxies /api to this target (no browser CORS). Use your ngrok or local Flask URL.
VITE_API_PROXY_TARGET=https://YOUR-SUBDOMAIN.ngrok-free.app

# Optional: call API directly from the browser (requires CORS on Backend).
# VITE_API_BASE_URL=https://YOUR-SUBDOMAIN.ngrok-free.app

# Optional: default operator profile id (see src/config/operators.ts).
# VITE_DASHBOARD_OPERATOR_ID=default
