{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@tma/config": ["../../packages/config/src/index.ts"],
      "@tma/analytics-gallery": ["../../packages/analytics-gallery/src/index.ts"],
      "@tma/analytics-museum": ["../../packages/analytics-museum/src/index.ts"],
      "@tma/dashboard-scope": ["../../packages/dashboard-scope/src/index.ts"],
      "@tma/dashboard-ui": ["../../packages/dashboard-ui/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
